# DeepSeek API — used by /api/summary for the AI news digest.
DEEPSEEK_API_KEY=your_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# DeepLX token — used to translate non-Chinese news titles & summaries to
# Chinese. Get one at https://connect.linux.do (requires a LINUX DO account).
# When unset, the feed shows in its original language.
DEEPLX_TOKEN=your_deeplx_token
# DEEPLX_BASE_URL=https://api.deeplx.org

# Optional: expose /api/debug outside local development (e.g. on Vercel
# production). Leave unset to keep the endpoint hidden in production.
# ENABLE_DEBUG=1
